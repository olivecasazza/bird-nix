{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bird-Nix",
  "scopeName": "source.bird-nix",
  "patterns": [
    { "include": "#comments" },
    { "include": "#birds" },
    { "include": "#operators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.number-sign.bird-nix",
        "match": "#.*$"
      }]
    },
    "birds": {
      "patterns": [{
        "name": "entity.name.function.bird.bird-nix",
        "match": "\\b(identityBird|mockingbird|kestrel|kite|bluebird|warbler|starling|lark|sageBird)\\b"
      }, {
        "name": "keyword.control.bird-nix",
        "match": "\\b(M|K|KI|B|W|S|L|Y|I)\\b"
      }]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.bird-nix",
        "match": "(->|=>|→)"
      }, {
        "name": "keyword.operator.lambda.bird-nix",
        "match": "(λ|lambda)"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.bird-nix",
        "begin": "\"",
        "end": "\"",
        "patterns": [{ "name": "constant.character.escape.bird-nix", "match": "\\\\" }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.bird-nix",
        "match": "\\b[0-9]+\\b"
      }]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.other.bird-nix",
        "match": "\\b(let|in|rec|if|then|else|with|inherit|import|builtins)\\b"
      }]
    }
  }
}
